          {
            "node": "Respond Immediately",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Batch Start": {
      "main": [
        [
          {
            "node": "Split Into Individual Payments",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Split Into Individual Payments": {
      "main": [
        [
          {
            "node": "Process in Batches of 10",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Process in Batches of 10": {
      "main": [
        [
          {
            "node": "Rate Limit (1s)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Rate Limit (1s)": {
      "main": [
        [
          {
            "node": "Send Payment",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Payment": {
      "main": [
        [
          {
            "node": "Generate Batch Report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [
    {
      "name": "devengo"
    },
    {
      "name": "bulk"
    }
  ],
  "id": "cf8f59bf548247578b64"
